{
	"name": "@kagchi/robochi-core",
	"version": "0.0.0",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target bun",
		"dev": "bun run --watch ./src/index.ts",
