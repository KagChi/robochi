		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"dependencies": {
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	}
}
