{
	"name": "@kagchi/robochi-worker",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run ./src/index.ts",
		"build": "bun build ./src/index.ts --outdir ./dist --target bun",
		"start": "bun run ./dist/index.js",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf ./dist"
	},
	"dependencies": {
		"@kagchi/robochi-core": "workspace:*",
		"octokit": "^4.0.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "latest"
	}
}
